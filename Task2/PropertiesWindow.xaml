<Window x:Class="Task2.PropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Task2"
        mc:Ignorable="d"
        Title="PropertiesWindow" 
        Height="auto" 
        Width="auto"
        WindowStyle="None">
    <Grid>
        <StackPanel>
            <Button Width="160" Height="30" 
                    FontSize="20" Content="Добавить" Click="Add_Click"/>

            <Button Width="160" Height="30"
                    FontSize="20" Content="Изменить" Click="Edit_Click"/>

            <Button Width="160" Height="30"
                    FontSize="20" Content="Удалить" Click="Delete_Click"/>            
        </StackPanel>
    </Grid>
</Window>
