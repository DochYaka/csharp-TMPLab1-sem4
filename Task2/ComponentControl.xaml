<UserControl x:Class="Task2.ComponentControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Task2"
        mc:Ignorable="d"
        FontSize="20"
        Height="auto"
        Width="auto"
        Loaded="Window_Loaded">
    <Grid>

        <StackPanel Width="800">

            <WrapPanel>
                <Button Width="160" Height="30"
                        Content="Добавить"
                        Click="Add_Click" x:Name="AddButton"/>

                <Button Width="160" Height="30"
                        Content="Изменить"
                        Click="Edit_Click" x:Name="EditButton" IsEnabled="False"/>

                <Button Width="160" Height="30"
                        Content="Отменить"
                        Click="Cancel_Click" x:Name="CancelButton"/>

                <Button Width="160" Height="30"
                        Content="Сохранить"
                        Click="Save_Click" x:Name="SaveButton"/>

                <Button Width="160" Height="30"
                        Content="Удалить"
                        Click="Delete_Click" x:Name="DeleteButton" IsEnabled="False"/>
            </WrapPanel>

            <ListView Width="800" ItemsSource="{Binding Components}"
                      x:Name="ComponentListView" SelectionChanged="ComponentsList_SelectionChanged">
                <ListView.View>
                    <GridView>

                        <GridViewColumn Width="200" DisplayMemberBinding="{Binding ComponentName}">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader >
                                    <StackPanel>
                                        <TextBlock Text="Наименование"/>
                                    </StackPanel>
                                </GridViewColumnHeader>
                            </GridViewColumn.Header>
                        </GridViewColumn>

                        <GridViewColumn Width="100" DisplayMemberBinding="{Binding ComponentType}">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader>
                                    <StackPanel>
                                        <TextBlock Text="Тип"/>
                                    </StackPanel>
                                </GridViewColumnHeader>
                            </GridViewColumn.Header>
                        </GridViewColumn>

                    </GridView>
                </ListView.View>
            </ListView>

            <DockPanel Width="800" Background="White">
                <WrapPanel DockPanel.Dock="Left">
                    <TextBlock Margin="10" Text="Наименование"/>
                    <TextBox Margin="10" Width="300" x:Name="NameTextBox"/>
                </WrapPanel>

                <WrapPanel DockPanel.Dock="Right">
                    <TextBlock Margin="10" Text="Тип"/>
                    <ComboBox Margin="10" Width="150" x:Name="TypeComboBox"/>
                </WrapPanel>
            </DockPanel>

        </StackPanel>
    </Grid>
</UserControl>
