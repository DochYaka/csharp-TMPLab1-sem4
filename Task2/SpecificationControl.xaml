<UserControl x:Class="Task2.SpecificationControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Task2"
        mc:Ignorable="d"
        FontSize="20"
        Height="auto"
        Width="auto"
        Background="White">
    <Grid>
        <StackPanel>

            <WrapPanel>
                <TextBox x:Name="SearchTextBox" Margin="10, 5, 0, 5" Width="350" TextChanged="SearchTextBox_TextChanged"/>

                <Button x:Name="btnCreate" Content="Создать тест" Click="BtnCreate_Click" Width="80" Margin="5"/>
            </WrapPanel>

            <TreeView Height="auto" x:Name="treeView" Margin="5" BorderBrush="Gray" BorderThickness="1"
                      SelectedItemChanged="TreeView_SelectedItemChanged">
                <TreeView.Resources>
                    <ContextMenu x:Key="NodeContextMenu">
                        <MenuItem Header="Добавить" Click="AddMenuItem_Click"/>
                        <MenuItem Header="Изменить" Click="EditMenuItem_Click"/>
                        <MenuItem Header="Удалить" Click="DeleteMenuItem_Click"/>
                    </ContextMenu>
                </TreeView.Resources>
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="ContextMenu" Value="{StaticResource NodeContextMenu}"/>
                    </Style>
                </TreeView.ItemContainerStyle>
            </TreeView>
        </StackPanel>
    </Grid>
</UserControl>