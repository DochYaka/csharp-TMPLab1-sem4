<Window x:Class="Task2.SpecificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Task2"
        mc:Ignorable="d"
        Title="Спецификация"
        FontSize="20"
        Height="300"
        Width="auto"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <StackPanel>
            
            <WrapPanel>
                <TextBox Margin="10, 5, 0, 5" Width="350"/>

                <Button x:Name="btnCreate" Content="Создать тест" Click="BtnCreate_Click" Width="80" Margin="5"/>
            </WrapPanel>

            <TreeView x:Name="treeView" Grid.Row="1" Margin="5" BorderBrush="Gray" BorderThickness="1"/>

        </StackPanel>
    </Grid>
</Window>
