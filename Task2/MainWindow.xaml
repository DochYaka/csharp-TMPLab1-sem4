<Window x:Class="Task2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Task2"
        mc:Ignorable="d"
        Title="Многосвязные списки"
        FontSize="20"
        Height="auto"
        Width="auto"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <StackPanel>

            <Menu Height="25" VerticalAlignment="Top">
                <MenuItem Header="Открыть" Click="OpenFile_Click"/>
                <MenuItem Header="Компоненты" Click="ComponentList_Click"/>
                <MenuItem Header="Спецификация" Click="SpecificationList_Click"/>
            </Menu>

            <ContentControl x:Name="ContentArea" Margin="5"/>
            
        </StackPanel>
    </Grid>
</Window>
