<Window x:Class="Task2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Task2"
        mc:Ignorable="d"
        Title="Многосвязные списки"
        Height="Auto"
        Width="800"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <WrapPanel>
            <Button Width="150" Height="35" FontSize="20" Content="Открыть" Click="OpenFile_Click"/>

            <Button Width="150" Height="35" FontSize="20" Content="Компоненты" Click="ComponentList_Click"/>

            <Button Width="150" Height="35" FontSize="20" Content="Спецификация" Click="SpecificationList_Click"/>
        </WrapPanel>
    </Grid>
</Window>
